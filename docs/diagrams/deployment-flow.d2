direction: down

title: {
  label: Deployment Flow — GitOps CI/CD
  near: top-center
  style.font-size: 18
  style.bold: true
}

dev: Developer {
  shape: person
  style.fill: "#E3F2FD"
}

pr: Pull Request {
  shape: rectangle
  style.fill: "#F5F5F5"
}

ci_test: ci.yml\nRun Tests {
  shape: rectangle
  style.fill: "#FFF9C4"
}

main: main branch {
  shape: rectangle
  style.fill: "#E8F5E9"
  style.bold: true
}

build: deploy.yml\nbuild-and-push (matrix) {
  shape: rectangle
  style.fill: "#FFF9C4"

  b1: Build auth-service {shape: rectangle}
  b2: Build user-service {shape: rectangle}
  b3: Build api-gateway  {shape: rectangle}
}

ecr: Amazon ECR {
  shape: cylinder
  style.fill: "#E8F5E9"
  style.stroke: "#43A047"
  label: "image:SHORT_SHA\nimage:latest"
}

update: deploy.yml\nupdate-manifests {
  shape: rectangle
  style.fill: "#FFF9C4"
  label: "sed newTag → SHORT_SHA\ngit commit [skip ci]\ngit push"
}

repo: GitHub Repo\nk8s/overlays/dev/kustomization.yaml {
  shape: rectangle
  style.fill: "#F3E5F5"
}

argocd: ArgoCD\n(polls every 3 min / webhook) {
  shape: rectangle
  style.fill: "#FFF8E1"
}

wave_neg1: Sync Wave -1\nApply SealedSecrets {
  shape: rectangle
  style.fill: "#FCE4EC"
}

ss: Sealed Secrets Controller\ndecrypt → create real Secrets {
  shape: rectangle
  style.fill: "#FCE4EC"
}

wave_0: Sync Wave 0\nApply Deployments / HPAs / Ingress {
  shape: rectangle
  style.fill: "#E8F5E9"
}

rollout: Rolling Update\n(zero downtime) {
  shape: rectangle
  style.fill: "#C8E6C9"
}

hpa: HPA monitors\nCPU / Memory {
  shape: rectangle
  style.fill: "#E3F2FD"
}

prom: Prometheus scrapes\n/actuator/prometheus {
  shape: rectangle
  style.fill: "#FBE9E7"
}

grafana: Grafana\ndashboards live {
  shape: rectangle
  style.fill: "#FBE9E7"
}

# Flow
dev -> pr: git push feature branch
pr -> ci_test: triggers ci.yml
ci_test -> main: PR merged
main -> build: triggers deploy.yml
build.b1 -> ecr: push image
build.b2 -> ecr: push image
build.b3 -> ecr: push image
build -> update: after all matrix jobs succeed
update -> repo: commit newTag
repo -> argocd: diff detected
argocd -> wave_neg1
wave_neg1 -> ss
ss -> wave_0: Secrets exist
wave_0 -> rollout
rollout -> hpa: pods running
rollout -> prom: metrics exposed
prom -> grafana
