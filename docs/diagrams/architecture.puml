@startuml architecture
!theme plain
skinparam backgroundColor #FAFAFA
skinparam defaultFontName "Helvetica"
skinparam defaultFontSize 13
skinparam ArrowColor #555555
skinparam componentStyle rectangle

skinparam component {
    BackgroundColor #EEF4FF
    BorderColor #5B8DEF
    FontColor #1A1A2E
}
skinparam database {
    BackgroundColor #FFF3E0
    BorderColor #FB8C00
}
skinparam cloud {
    BackgroundColor #E8F5E9
    BorderColor #43A047
}
skinparam node {
    BackgroundColor #F3E5F5
    BorderColor #8E24AA
}
skinparam rectangle {
    BackgroundColor #E3F2FD
    BorderColor #1E88E5
}

title MusicSync Platform — High-Level Architecture

actor "Client Browser" as client

cloud "AWS — eu-central-1" {

    rectangle "AWS Services" {
        component "ECR\n(6 repositories / env)" as ecr
        component "IAM OIDC Provider\n(GitHub Actions)" as oidc
    }

    rectangle "VPC  10.0.0.0/16" {

        rectangle "Public Subnets (10.0.1.0/24, 10.0.2.0/24)" {
            component "Internet Gateway" as igw
            component "NAT Gateway" as nat
            component "Traefik NLB\n(LoadBalancer)" as lb
        }

        rectangle "Private Subnets (10.0.11.0/24, 10.0.12.0/24)" {

            node "EKS Node Group" {
                rectangle "Namespace: jv-eks" {
                    component "API Gateway\n:8080" as gw
                    component "Auth Service\n:8081" as auth
                    component "User Service\n:8082" as user
                    component "Crate Service\n:8083" as crate
                    component "Sync Service\n:8084" as sync
                }
                rectangle "Namespace: kube-system" {
                    component "Sealed Secrets\nController" as ss
                    component "Metrics Server" as ms
                }

                rectangle "Namespace: Traefik" {
                    component "Traefik\n(Ingress)" as traefik
                }

                rectangle "Namespace: argocd" {
                    component "ArgoCD" as argocd
                }
                rectangle "Namespace: monitoring" {
                    component "Prometheus" as prom
                    component "Grafana" as grafana
                    component "Alertmanager" as alert
                }
            }

            database "RDS PostgreSQL 16" as rds
            database "ElastiCache Redis" as redis
        }
    }
}

rectangle "GitHub" {
    component "Source Code\n+ K8s Manifests" as repo
    component "GitHub Actions\n(CI/CD)" as ci
}

' Traffic flow
client --> lb : HTTPS/HTTP
lb --> traefik
traefik --> gw : /api/* + /ws/sync
' note right of gw
'     Gateway routes to backend services
'     (auth, user, crate, sync)
' end note

' Data
auth --> rds : JDBC :5432 (auth_db)
user --> rds : JDBC :5432 (user_db)
crate --> rds : JDBC :5432 (crate_db)
crate --> redis : cache + pub/sub
sync --> redis : pub/sub

' GitOps
' ci --> ecr : docker push
' ci --> repo : commit newTag [skip ci]
argocd --> repo : poll / webhook
' argocd --> traefik : kubectl apply
' argocd --> gw : kubectl apply
' argocd --> auth : kubectl apply
' argocd --> user : kubectl apply
' argocd --> crate : kubectl apply
' argocd --> sync : kubectl apply

' Secrets
ss --> auth : decrypt -> Secret
ss --> user : decrypt -> Secret
ss --> crate : decrypt -> Secret

' Observability
' prom --> auth : scrape /actuator/prometheus
' prom --> user : scrape /actuator/prometheus
' prom --> gw   : scrape /actuator/prometheus
' prom --> crate : scrape /actuator/prometheus
' prom --> sync : scrape /actuator/prometheus
' grafana --> prom : query

' OIDC auth
ci --> oidc : AssumeRoleWithWebIdentity
oidc --> ecr : ECR PowerUser

' Egress
nat --> rds : private routing
nat --> redis : private routing

@enduml
