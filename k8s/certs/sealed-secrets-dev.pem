# This file is intentionally empty — it is populated once after the first `tofu apply`.
#
# Fetch with:
#   kubeseal --controller-namespace kube-system \
#            --controller-name sealed-secrets \
#            --fetch-cert > k8s/certs/sealed-secrets-dev.pem
#
# Then commit it:
#   git add k8s/certs/sealed-secrets-dev.pem
#   git commit -m "chore: commit sealed-secrets public cert for dev"
#
# The cert is the PUBLIC key only — it is safe to commit.
# Keep it here so teammates and CI can seal new secrets without cluster access.
